  <property name="styleSheet">
   <string notr="true">/* TŁO I OGÓLNA CZCIONKA */
QWidget {
    background-color: #c0c0c0;
    color: black;
    font-family: &quot;MS Sans Serif&quot;, Arial;
    font-size: 16px; /* Zwiększamy z 14px na 16px (lub 18px jak wolisz wielkie) */
}

/* POLA LICZBOWE - WYSOKIE I WYRAŹNE */
QDoubleSpinBox, QSpinBox, QComboBox {
    background-color: white;
    border: 2px solid #404040;
    border-bottom-color: #ffffff;
    border-right-color: #ffffff;
    min-height: 35px; /* To robi robotę! Pola będą wysokie */
    padding: 5px;     /* Oddech dla tekstu w środku */
}

/* PRZYCISKI - MASYWNE */
QPushButton {
    background-color: #c0c0c0;
    border: 2px solid #ffffff;
    border-bottom-color: #404040;
    border-right-color: #404040;
    min-height: 40px; /* Wysokie przyciski */
    font-weight: bold;
    font-size: 16px;
}
QPushButton:pressed {
    border: 2px solid #404040;
    border-bottom-color: #ffffff;
    border-right-color: #ffffff;
    background-color: #b0b0b0;
}

/* LABELES (ETYKIETY) */
QLabel {
    font-weight: bold; /* Żeby napisy &quot;Okres:&quot; itp. były grube */
    padding-right: 5px;
}

/* GROUPBOX - GRUBY TYTUŁ */
QGroupBox {
    border: 2px solid #808080;
    border-radius: 4px;
    margin-top: 30px; /* Więcej miejsca na tytuł */
    font-size: 18px;  /* Tytuł grupy większy niż reszta */
    font-weight: bold;
}
QGroupBox::title {
    subcontrol-origin: margin;
    left: 15px;
    padding: 0 5px;
}

/* WYKRESY */
#wykres1, #wykres2, #wykres3, #wykres4 {
    background-color: black;
    border: 2px solid #808080;
}
QCheckBox {
    font-size: 16px;
    font-weight: bold;
    color: black;
    spacing: 10px; /* Odstęp tekstu od obrazka */
}

/* BAZOWY STYL INDICATORA (To jest stan domyślny - ODZNACZONY) */
QCheckBox::indicator {
    width: 32px;
    height: 32px;
    background: none;
    border: none;
    image: url(:/new/prefix1/checkbox-pusty.png);
}

QCheckBox::indicator:checked {
    image: url(:/new/prefix1/checkbox.png);
}
/* --- STYL DLA WYŁĄCZONYCH PÓL (To sprawi, że zszarzeją) --- */
QDoubleSpinBox:disabled, QSpinBox:disabled, QComboBox:disabled {
    background-color: #d0d0d0; /* Tło takie jak okna lub lekko inne */
    color: #606060;            /* Tekst ciemnoszary (nie czarny) */
    border: 2px solid #808080; /* Ramka też bledsza */
}</string>
